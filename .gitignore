# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.idea/
.vscode/
*.swp
*.swo

# Claude Code 本地配置
.claude/settings.local.json

# Temp files
temp/
*.tmp
*.temp

# Local config
local.config.md
relink.local.sh
*.local.sh

# ========== 项目数据隐私保护 ==========
# 只公开 EXAMPLE 作为示例项目，其他真实项目数据不提交
# 注意：projects/AI-TASK/ 为内部自治空间（DDAC 自治理），同样不公开

# 忽略 projects 下的所有项目目录
projects/*/

# 但保留 EXAMPLE 目录（示例项目，完整公开）
!projects/EXAMPLE/

# 保留目录结构占位符
!projects/*/tasks/.gitkeep
!projects/*/docs/.gitkeep

# 全局归档目录（历史敏感数据）
archive/

# EXAMPLE 归档目录公开（示例展示完整生命周期）
!projects/EXAMPLE/archive/
!projects/EXAMPLE/archive/**

# Rules 中的真实项目规则（可能包含敏感架构信息）
rules/
!rules/README.md
